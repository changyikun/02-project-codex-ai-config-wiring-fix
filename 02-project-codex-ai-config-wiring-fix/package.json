{
  "name": "palace-ai-game",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/src/index.ts",
    "build": "npm run build:web && npm run build:api",
    "build:web": "tsc -p tsconfig.json && vite build",
    "build:api": "tsup server/src/index.ts --format esm,cjs --dts --out-dir dist-server",
    "preview:web": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run server/tests/unit",
    "test:integration": "vitest run server/tests/integration",
    "test:coverage": "vitest run --coverage",
    "perf": "node scripts/perf/ai-contract.perf.cjs",
    "perf:foundation": "node scripts/perf/foundation-stress.perf.cjs",
    "export:foundation-config": "node scripts/export-foundation-config.cjs",
    "assets:process": "node scripts/process-route-assets.cjs"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "fastify": "^5.2.1",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.4.2",
    "pino": "^9.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.0.5",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "autocannon": "^8.0.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.9",
    "sharp": "^0.34.5",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.8",
    "xlsx": "^0.18.5"
  }
}
